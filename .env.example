# Required for login and sessions
APP_PASSWORD=replace-with-a-strong-password
FLASK_SECRET_KEY=replace-with-a-long-random-value

# Model providers
OPENROUTER_API_KEY=replace-with-your-openrouter-key
ANTHROPIC_API_KEY=replace-with-your-anthropic-key

# Character model overrides
MODEL_CHAR1=google/gemini-3-flash-preview
MODEL_CHAR2=openai/gpt-4o-mini
MODEL_CHAR3=google/gemini-3-flash-preview
MODEL_CHAR4=x-ai/grok-4.3
MODEL_CHAR5=claude-sonnet-4-6
MODEL_CHAR6=anthropic/claude-fable-5
SUMMARY_MODEL=google/gemini-2.5-flash-lite

# Storage
DB_PATH=becoming.db
# UPLOAD_ROOT=/absolute/path/to/chat_uploads
# BECOMING_MEMORY_DIR=/absolute/path/to/becoming_memory

# Long-term memory: embedded (default), disabled, or module.path:factory.
# Custom backends only need recall(owner_id) and save(content, owner_id, **metadata).
MEMORY_BACKEND=embedded

# Scheduling
SCHEDULER_TIMEZONE=UTC
SCHEDULER_ENABLED=true
DESIRE_DRIVEN=true
DESIRE_TICK_MINUTES=10
GROUP_SUMMARY_THRESHOLD=40

# Optional Android/iOS companion push bridge. Disabled by default. Music sync,
# voice, and read-only phone search use an operator-controlled companion or
# custom MCP connection; see docs/MOBILE_EXTENSIONS.md.
# MOBILE_PUSH_ENABLED=false
# MOBILE_PUSH_WEBHOOK_URL=https://companion.example.com/becoming/events
# MOBILE_PUSH_WEBHOOK_SECRET=replace-with-at-least-16-random-characters
# MOBILE_PUSH_TIMEOUT=5

# Optional memory metadata analysis. OPENROUTER_API_KEY is reused when these
# direct-provider keys are empty.
# OMBRE_API_KEY=replace-with-your-deepseek-key
# OMBRE_DEHYDRATION_API_KEY=replace-with-your-deepseek-key
# OMBRE_DEHYDRATION_MODEL=deepseek-chat
# OMBRE_DEHYDRATION_BASE_URL=https://api.deepseek.com/v1

# Optional semantic embeddings
# OMBRE_EMBEDDING_API_KEY=replace-with-your-google-ai-studio-key
# OMBRE_EMBEDDING_MODEL=gemini-embedding-2
# OMBRE_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional runtime tuning
# OMBRE_ENRICHMENT_WORKERS=2
# OMBRE_ENRICHMENT_TIMEOUT=45
# OMBRE_EMBEDDING_TIMEOUT=30
# MAX_UPLOAD_BYTES=10485760
# PORT=5000
# WEB_CONCURRENCY=1
# GUNICORN_TIMEOUT=300
